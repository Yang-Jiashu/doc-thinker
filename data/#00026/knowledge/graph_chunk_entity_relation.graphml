    <node id="Wheel-Track Transformable Mobile Reconnaissance and Search-Rescue Robot">
      <data key="entity_id">Wheel-Track Transformable Mobile Reconnaissance and Search-Rescue Robot</data>
      <data key="entity_type">artifact</data>
      <data key="description">The Wheel-Track Transformable Mobile Reconnaissance and Search-Rescue Robot is an innovative, unmanned ground reconnaissance robot capable of transforming between wheel and track modes for fast movement, strong obstacle-crossing capabilities, and adaptability to complex terrains. It is lightweight, portable, remote-controlled, and supports multi-machine collaboration.</data>
      <data key="source_id">chunk-9f4adf47acbf868d88c085f774e292ca</data>
      <data key="file_path">产品说明书.pdf</data>
      <data key="created_at">1772954401</data>
      <data key="truncate" />
    </node>
    <node id="Police and Counter-Terrorism Robot">
      <data key="entity_id">Police and Counter-Terrorism Robot</data>
      <data key="entity_type">artifact</data>
      <data key="description">Police and Counter-Terrorism Robot refers to robots developed for police and counter-terrorism applications, including reconnaissance, bomb disposal, firefighting, and attack functions.</data>
      <data key="source_id">chunk-9f4adf47acbf868d88c085f774e292ca</data>
      <data key="file_path">产品说明书.pdf</data>
      <data key="created_at">1772954401</data>
      <data key="truncate" />
    </node>
    <node id="Modular Friction Drive Wheel-Track Platform">
      <data key="entity_id">Modular Friction Drive Wheel-Track Platform</data>
      <data key="entity_type">artifact</data>
      <data key="description">The Modular Friction Drive Wheel-Track Platform is a platform using friction drive and modular design, allowing seamless transition between wheel and track configurations in reconnaissance and search-rescue robots.</data>
      <data key="source_id">chunk-9f4adf47acbf868d88c085f774e292ca</data>
      <data key="file_path">产品说明书.pdf</data>
      <data key="created_at">1772954401</data>
      <data key="truncate" />
    </node>
    <node id="Crank-Rocker Mechanism">
      <data key="entity_id">Crank-Rocker Mechanism</data>
      <data key="entity_type">concept</data>
      <data key="description">Crank-Rocker Mechanism is a mechanical structure used in the robot to enable transformation between wheel and track modes.</data>
      <data key="source_id">chunk-9f4adf47acbf868d88c085f774e292ca</data>
      <data key="file_path">产品说明书.pdf</data>
      <data key="created_at">1772954401</data>
      <data key="truncate" />
    </node>
    <node id="Elasticity">
      <data key="entity_id">Elasticity</data>
      <data key="entity_type">concept</data>
      <data key="description">Elasticity refers to the physical property employed in the robot’s structure to facilitate wheel-track switching.</data>
      <data key="source_id">chunk-9f4adf47acbf868d88c085f774e292ca</data>
      <data key="file_path">产品说明书.pdf</data>
      <data key="created_at">1772954401</data>
      <data key="truncate" />
    </node>
