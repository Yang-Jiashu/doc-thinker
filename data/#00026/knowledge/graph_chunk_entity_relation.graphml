    <node id="Friction-Driven Reconnaissance And Search And Rescue Robot">
      <data key="entity_id">Friction-Driven Reconnaissance And Search And Rescue Robot</data>
      <data key="entity_type">artifact</data>
      <data key="description">The Friction-Driven Reconnaissance And Search And Rescue Robot is a platform based on friction drive, featuring an elastic wheel/track transformation mechanism, designed for high obstacle-crossing capabilities and adaptation to highly structured search and rescue environments.&lt;SEP&gt;The Friction-Driven Reconnaissance And Search And Rescue Robot is a robot platform based on a friction-driven mechanism designed for reconnaissance and search and rescue missions.</data>
      <data key="source_id">chunk-9f4adf47acbf868d88c085f774e292ca&lt;SEP&gt;chunk-0c1095ee0cd81abde001bbc79696e301</data>
      <data key="file_path">产品说明书.pdf</data>
      <data key="created_at">1772954401</data>
      <data key="truncate" />
    </node>
    <node id="Crank Linkage Mechanism">
      <data key="entity_id">Crank Linkage Mechanism</data>
      <data key="entity_type">artifact</data>
      <data key="description">The Crank Linkage Mechanism is a structure used within the wheel/track robot to achieve switching between wheel and track modes.&lt;SEP&gt;The Crank Linkage Mechanism is a component that enables the wheels or tracks of the robot to switch modes by leveraging the elasticity of the components and a crank linkage structure.</data>
      <data key="source_id">chunk-9f4adf47acbf868d88c085f774e292ca&lt;SEP&gt;chunk-0c1095ee0cd81abde001bbc79696e301</data>
      <data key="file_path">产品说明书.pdf</data>
      <data key="created_at">1772954401</data>
      <data key="truncate" />
    </node>
    <node id="Stanchion Mechanism">
      <data key="entity_id">Stanchion Mechanism</data>
      <data key="entity_type">artifact</data>
      <data key="description">The Stanchion Mechanism is an auxiliary device equipped on the transformation robot, enhancing its maximum obstacle-crossing height to 15 cm.</data>
      <data key="source_id">chunk-9f4adf47acbf868d88c085f774e292ca</data>
      <data key="file_path">产品说明书.pdf</data>
      <data key="created_at">1772954401</data>
      <data key="truncate" />
    </node>
    <node id="Remote Control">
      <data key="entity_id">Remote Control</data>
      <data key="entity_type">method</data>
      <data key="description">Remote Control allows human operators to control the robot in real-time via transmitted data and images.&lt;SEP&gt;Remote Control is a usage mode supported by the transformation robot, allowing it to be operated from a distance, including over 4G networks.</data>
      <data key="source_id">chunk-9f4adf47acbf868d88c085f774e292ca&lt;SEP&gt;chunk-0c1095ee0cd81abde001bbc79696e301</data>
