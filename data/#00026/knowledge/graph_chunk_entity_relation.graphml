      <data key="entity_id">Support Rod Mechanism</data>
      <data key="entity_type">artifact</data>
      <data key="description">Support Rod Mechanism is a component that allows the robot to overcome obstacles up to a maximum height of 15 cm.</data>
      <data key="source_id">chunk-9f4adf47acbf868d88c085f774e292ca</data>
      <data key="file_path">产品说明书.pdf</data>
