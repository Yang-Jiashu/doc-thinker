    <node id="Police Robot">
      <data key="entity_id">Police Robot</data>
      <data key="entity_type">artifact</data>
      <data key="description">Police Robot refers to a category of robots developed for law enforcement purposes, including reconnaissance, explosive ordnance disposal, firefighting, attack, and multiple functions, and has seen significant development and achievements in China over the past 30 years.</data>
      <data key="source_id">chunk-9f4adf47acbf868d88c085f774e292ca</data>
