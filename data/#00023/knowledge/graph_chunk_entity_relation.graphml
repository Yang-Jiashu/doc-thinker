  <graph edgedefault="undirected">
    <node id="I/O System">
      <data key="entity_id">I/O System</data>
      <data key="entity_type">concept</data>
      <data key="description">The I/O System encompasses all hardware and logic responsible for input and output operations in a computer system.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="I/O Device">
      <data key="entity_id">I/O Device</data>
      <data key="entity_type">artifact</data>
      <data key="description">I/O Devices are peripheral hardware components that facilitate input, output, or both between the computer and the external environment.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="I/O Interface">
      <data key="entity_id">I/O Interface</data>
      <data key="entity_type">artifact</data>
      <data key="description">The I/O Interface is a hardware and protocol mechanism that connects I/O devices to the computer system, managing communication and data exchange.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="I/O Port">
      <data key="entity_id">I/O Port</data>
      <data key="entity_type">artifact</data>
      <data key="description">I/O Port is a specific terminal or access point through which data and control signals are sent to or received from an I/O device.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="I/O Controller">
      <data key="entity_id">I/O Controller</data>
      <data key="entity_type">artifact</data>
      <data key="description">The I/O Controller is a component that manages and coordinates data exchange between the computer and its I/O devices.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="I/O Channel">
      <data key="entity_id">I/O Channel</data>
      <data key="entity_type">artifact</data>
      <data key="description">The I/O Channel is a dedicated data path or protocol that manages communication between the CPU, memory, and I/O devices.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Input Device">
      <data key="entity_id">Input Device</data>
      <data key="entity_type">artifact</data>
      <data key="description">An Input Device is a category of I/O devices designed to capture data from the external world and transmit it to the computer.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Output Device">
      <data key="entity_id">Output Device</data>
      <data key="entity_type">artifact</data>
      <data key="description">An Output Device is a type of I/O device that presents or sends processed data from the computer to the external environment.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Input/Output Device">
      <data key="entity_id">Input/Output Device</data>
      <data key="entity_type">artifact</data>
      <data key="description">An Input/Output Device supports both input and output functionalities, enabling two-way data exchange with the computer.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Block Device">
      <data key="entity_id">Block Device</data>
      <data key="entity_type">artifact</data>
      <data key="description">A Block Device is an I/O device that manages data in fixed-size blocks, allowing random access and storage operations.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Character Device">
      <data key="entity_id">Character Device</data>
      <data key="entity_type">artifact</data>
      <data key="description">A Character Device is an I/O device that manages data as a stream of characters, typically handling data sequentially.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Low-Speed Device">
      <data key="entity_id">Low-Speed Device</data>
      <data key="entity_type">artifact</data>
      <data key="description">A Low-Speed Device is a classification of I/O devices that operate at a relatively slow data transfer rate.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Medium-Speed Device">
      <data key="entity_id">Medium-Speed Device</data>
      <data key="entity_type">artifact</data>
      <data key="description">A Medium-Speed Device is an I/O device category characterized by moderate data transfer rates.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="High-Speed Device">
      <data key="entity_id">High-Speed Device</data>
      <data key="entity_type">artifact</data>
      <data key="description">A High-Speed Device is a type of I/O device that supports fast data transfer rates.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Parallel Interface">
      <data key="entity_id">Parallel Interface</data>
      <data key="entity_type">artifact</data>
      <data key="description">The Parallel Interface is a type of I/O interface where multiple data bits are transmitted simultaneously over several channels.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Serial Interface">
      <data key="entity_id">Serial Interface</data>
      <data key="entity_type">artifact</data>
      <data key="description">The Serial Interface is an I/O interface that transmits data sequentially, one bit at a time, over a single channel.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Data Port">
      <data key="entity_id">Data Port</data>
      <data key="entity_type">artifact</data>
      <data key="description">A Data Port is a type of I/O port specifically used for the transmission of data between the computer and I/O devices.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Status Port">
      <data key="entity_id">Status Port</data>
      <data key="entity_type">artifact</data>
      <data key="description">A Status Port is an I/O port designed for communicating the current status or condition of an I/O device to the computer system.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Control Port">
      <data key="entity_id">Control Port</data>
      <data key="entity_type">concept</data>
      <data key="description">Control port is a type of I/O port used for sending commands or control signals to I/O devices.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Host Interface">
      <data key="entity_id">Host Interface</data>
      <data key="entity_type">artifact</data>
      <data key="description">The Host Interface is a component within the I/O controller that connects and coordinates communication with the main computer.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Device Interface">
      <data key="entity_id">Device Interface</data>
      <data key="entity_type">concept</data>
      <data key="description">Device interface is a component of the I/O controller used for communication with the I/O device.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Control Logic">
      <data key="entity_id">Control Logic</data>
      <data key="entity_type">artifact</data>
      <data key="description">Control Logic refers to the circuitry or mechanism within the I/O controller that manages device control operations.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Select Channel">
      <data key="entity_id">Select Channel</data>
      <data key="entity_type">artifact</data>
      <data key="description">Select Channel is a type of I/O channel optimized for managing communications with a single device at a time.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Multiplex Channel">
      <data key="entity_id">Multiplex Channel</data>
      <data key="entity_type">artifact</data>
      <data key="description">Multiplex Channel is a type of I/O channel capable of managing communication with multiple devices simultaneously.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Programmed I/O">
      <data key="entity_id">Programmed I/O</data>
      <data key="entity_type">method</data>
      <data key="description">Programmed I/O is a data transfer method where the CPU actively checks I/O device status and handles all data transmissions.&lt;SEP&gt;Programmed I/O is a method where the CPU is directly responsible for data transfer to and from I/O devices, requiring constant software polling.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068&lt;SEP&gt;chunk-672f461a21cd2f086b04b07ff60921d7</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890440</data>
      <data key="truncate" />
    </node>
    <node id="Interrupt-Driven I/O">
      <data key="entity_id">Interrupt-Driven I/O</data>
      <data key="entity_type">method</data>
      <data key="description">Interrupt-Driven I/O is a transfer method where I/O devices notify the CPU via interrupts when ready, prompting the CPU to perform data transfer only upon request.&lt;SEP&gt;Interrupt-Driven I/O is a data transfer method where I/O devices signal the CPU via interrupts when ready for communication, reducing CPU involvement.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068&lt;SEP&gt;chunk-672f461a21cd2f086b04b07ff60921d7</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890440</data>
      <data key="truncate" />
    </node>
    <node id="DMA">
      <data key="entity_id">DMA</data>
      <data key="entity_type">method</data>
      <data key="description">DMA (Direct Memory Access) is a method that allows a controller to directly manage data transfers between memory and I/O devices, minimizing CPU involvement.&lt;SEP&gt;DMA (Direct Memory Access) is an I/O method where data can be transferred between memory and I/O devices independently of the CPU, managed by a dedicated controller.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068&lt;SEP&gt;chunk-672f461a21cd2f086b04b07ff60921d7</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890440</data>
      <data key="truncate" />
    </node>
    <node id="DMA Controller">
      <data key="entity_id">DMA Controller</data>
      <data key="entity_type">artifact</data>
      <data key="description">DMA Controller is the hardware component responsible for conducting direct memory access transfers between system memory and I/O devices.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Buffered Operation">
      <data key="entity_id">Buffered Operation</data>
      <data key="entity_type">concept</data>
      <data key="description">Buffered operation refers to the process in I/O interfaces that temporarily stores data to accommodate differences in speed between I/O devices and other system components.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Status Detection">
      <data key="entity_id">Status Detection</data>
      <data key="entity_type">concept</data>
      <data key="description">Status detection is a function of I/O interfaces that monitors the operational state of I/O devices.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Address Recognition">
      <data key="entity_id">Address Recognition</data>
      <data key="entity_type">concept</data>
      <data key="description">Address recognition is a feature of I/O interfaces used to identify and select the correct hardware address for data transfers.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Data Format Conversion">
      <data key="entity_id">Data Format Conversion</data>
      <data key="entity_type">concept</data>
      <data key="description">Data format conversion is a function of the I/O interface that translates data between different formats required by devices and the host system.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890394</data>
      <data key="truncate" />
    </node>
    <node id="Data Path">
      <data key="entity_id">Data Path</data>
      <data key="entity_type">concept</data>
      <data key="description">Data path is a component of I/O interface responsible for the transmission of data signals.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890395</data>
      <data key="truncate" />
    </node>
    <node id="Status/Control Path">
      <data key="entity_id">Status/Control Path</data>
      <data key="entity_type">concept</data>
      <data key="description">Status/control path is a component of I/O interface used to transmit status and control signals between the CPU and I/O devices.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890395</data>
      <data key="truncate" />
    </node>
    <node id="Address Path">
      <data key="entity_id">Address Path</data>
      <data key="entity_type">concept</data>
      <data key="description">Address path is a part of the I/O interface that carries address signals for identifying device or memory locations.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890396</data>
      <data key="truncate" />
    </node>
    <node id="Selector Channel">
      <data key="entity_id">Selector Channel</data>
      <data key="entity_type">concept</data>
      <data key="description">Selector channel is a type of I/O channel dedicated to handling data transfers for a single device at a time.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890396</data>
      <data key="truncate" />
    </node>
    <node id="Multiplexer Channel">
      <data key="entity_id">Multiplexer Channel</data>
      <data key="entity_type">concept</data>
      <data key="description">Multiplexer channel is a type of I/O channel that can control multiple devices concurrently by interleaving their data transfers.</data>
      <data key="source_id">chunk-2d5940b782faab253cf406e6cc9b0068</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772890396</data>
      <data key="truncate" />
    </node>
