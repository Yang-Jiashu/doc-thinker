  <graph edgedefault="undirected">
    <node id="User">
      <data key="entity_id">User</data>
      <data key="entity_type">person</data>
      <data key="description">User is a person posing a question but whose details are unspecified in the text.&lt;SEP&gt;User is an individual requesting assistance and clarification on a specific question.</data>
      <data key="source_id">chunk-b0fc34a86f588678d99a5c57b29d0b81&lt;SEP&gt;chunk-1999a04971a832ea2f31f010612e0243&lt;SEP&gt;chunk-4d976a9bc8846be1a523aa19572aed4b&lt;SEP&gt;chunk-9f6ca9eaf8a7253d1038d29afd3aac4b&lt;SEP&gt;chunk-7b306462f19a5387357a573fda2de387&lt;SEP&gt;chunk-c97c298ff0c6d37a45347233853c5648</data>
