    <node id="Non-Maximum Suppression">
      <data key="entity_id">Non-Maximum Suppression</data>
      <data key="entity_type">concept</data>
      <data key="description">NMS is a post-processing technique used in object detection that can slow down inference and introduce instability.&lt;SEP&gt;Non-Maximum Suppression (NMS) is a limitation of YOLO detectors discussed in the research paper.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-faafaa17742ca7c753025687b423a9a9</data>
