    <node id="T4 GPU">
      <data key="entity_id">T4 GPU</data>
      <data key="entity_type">artifact</data>
      <data key="description">T4 GPU is a graphics processing unit used for testing model performance.&lt;SEP&gt;T4 GPU is a hardware platform used to evaluate the performance of RT-DETR, achieving 108 / 74 FPS.&lt;SEP&gt;T4 GPU is a hardware platform used to measure the inference speed of RT-DETR, achieving 108 FPS.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-f8619065465d075892731f2a8b8555e6&lt;SEP&gt;chunk-56050e109fbbcac2d20804a62750188c</data>
