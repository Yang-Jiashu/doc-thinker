    <node id="RT-DETR-R50">
      <data key="entity_id">RT-DETR-R50</data>
      <data key="entity_type">artifact</data>
      <data key="description">RT-DETR-R50 is a version of RT-DETR that achieves 53.1% AP on COCO and 108 FPS on T4 GPU.&lt;SEP&gt;RT-DETR-R50 is a variant of the RT-DETR model with a ResNet-50 backbone, achieving 53.1% AP and 108 FPS.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-ef8c7ff567b0412204b7096eef345f02</data>
