    <node id="DETRs">
      <data key="entity_id">DETRs</data>
      <data key="entity_type">concept</data>
      <data key="description">DETRs are end-to-end Transformer-based detectors that eliminate the need for Non-Maximum Suppression (NMS).&lt;SEP&gt;DETRs refers to a class of object detection models that use transformer architectures for end-to-end detection.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-ef8c7ff567b0412204b7096eef345f02</data>
