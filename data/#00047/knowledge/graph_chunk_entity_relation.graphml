    <node id="Real-Time Object Detection">
      <data key="entity_id">Real-Time Object Detection</data>
      <data key="entity_type">concept</data>
      <data key="description">Real-time object detection is a research area with applications in autonomous driving, video surveillance, and more.&lt;SEP&gt;Real-Time Object Detection refers to the ability of a model to detect objects quickly and efficiently.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-ef8c7ff567b0412204b7096eef345f02</data>
