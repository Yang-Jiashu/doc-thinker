      <data key="entity_id">Objects365</data>
      <data key="entity_type">data</data>
      <data key="description">Objects365 is a pre-training dataset used to enhance the performance of RT-DETR, achieving 55.3% / 56.2% AP.&lt;SEP&gt;Objects365 is a large-scale dataset used for pre-training RT-DETR, leading to improved performance.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-f8619065465d075892731f2a8b8555e6</data>
