      <data key="truncate" />
    </node>
    <node id="YOLOs">
      <data key="entity_id">YOLOs</data>
      <data key="entity_type">concept</data>
      <data key="description">YOLOs are a series of real-time object detection frameworks known for their balance between speed and accuracy.&lt;SEP&gt;YOLOs are a family of real-time object detection models known for their speed and efficiency.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-ef8c7ff567b0412204b7096eef345f02</data>
