      <data key="entity_id">DINO-R50</data>
      <data key="entity_type">artifact</data>
      <data key="description">DINO-R50 is a previous state-of-the-art model that RT-DETR outperforms in both accuracy and speed.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724</data>
