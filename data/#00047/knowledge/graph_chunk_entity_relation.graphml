    <node id="Real-Time DEtection TRansformer">
      <data key="entity_id">Real-Time DEtection TRansformer</data>
      <data key="entity_type">artifact</data>
      <data key="description">RT-DETR is a real-time end-to-end object detector designed to address the limitations of YOLOs and DETRs.&lt;SEP&gt;Real-Time DEtection TRansformer is the full name of RT-DETR, an advanced object detection model.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-f8619065465d075892731f2a8b8555e6</data>
