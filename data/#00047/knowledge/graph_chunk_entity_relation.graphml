      <data key="entity_type">artifact</data>
      <data key="description">RT-DETR-R101 is a version of RT-DETR that achieves 54.3% AP on COCO and 74 FPS on T4 GPU.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724</data>
