      <data key="truncate" />
    </node>
    <node id="Transformer">
      <data key="entity_id">Transformer</data>
      <data key="entity_type">concept</data>
      <data key="description">Transformer is a neural network architecture used in DETRs for end-to-end object detection.&lt;SEP&gt;Transformer is the underlying architecture of the proposed RT-DETR model.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-faafaa17742ca7c753025687b423a9a9</data>
