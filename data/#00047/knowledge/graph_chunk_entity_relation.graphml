    </node>
    <node id="Hybrid Encoder">
      <data key="entity_id">Hybrid Encoder</data>
      <data key="entity_type">artifact</data>
      <data key="description">Hybrid encoder is an efficient design used in RT-DETR to process multi-scale features and improve inference speed.&lt;SEP&gt;The hybrid encoder is a component of RT-DETR designed to process multi-scale features efficiently.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-f8619065465d075892731f2a8b8555e6</data>
      <data key="file_path">23rfewdq.pdf</data>
      <data key="created_at">1773520656</data>
      <data key="truncate" />
    </node>
    <node id="Uncertainty-Minimal Query Selection">
      <data key="entity_id">Uncertainty-Minimal Query Selection</data>
      <data key="entity_type">method</data>
      <data key="description">Uncertainty-minimal query selection is a technique used in RT-DETR to select high-quality object queries based on localization confidence.&lt;SEP&gt;Uncertainty-minimal query selection is a technique used in RT-DETR to improve accuracy by selecting high-quality initial queries.&lt;SEP&gt;Uncertainty-Minimal Query Selection is a technique used in the RT-DETR model to reduce uncertainty in object detection.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-f8619065465d075892731f2a8b8555e6&lt;SEP&gt;chunk-ef8c7ff567b0412204b7096eef345f02</data>
