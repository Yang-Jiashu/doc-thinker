      <data key="entity_type">data</data>
      <data key="description">COCO is a dataset used for evaluating object detection models, achieving 53.1% / 54.3% AP with RT-DETR.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724</data>
