    <node id="RT-DETR Performance Comparison Chart (image)">
      <data key="entity_id">RT-DETR Performance Comparison Chart (image)</data>
      <data key="entity_type">image</data>
      <data key="description">This image presents Figure 1 from the RT-DETR research paper, illustrating a performance benchmark between the proposed RT-DETR model and existing YOLO series detectors (v5 through v8). The scatter plot maps COCO Average Precision (AP) against inference latency on a T4 GPU. It visually substantiates the paper's claim that RT-DETR achieves superior speed-accuracy trade-offs, positioning the red RT-DETR curve above and to the left of competing models, indicating higher accuracy with lower latency.</data>
      <data key="source_id">chunk-f6b2736f01bc36e3d1371f9309a3ef7a</data>
      <data key="file_path">23rfewdq.pdf</data>
      <data key="created_at">1773518805</data>
    </node>
    <node id="RT-DETR Paper Page 2 (image)">
      <data key="entity_id">RT-DETR Paper Page 2 (image)</data>
      <data key="entity_type">image</data>
      <data key="description">This image shows page 2 of the research paper introducing RT-DETR, a real-time end-to-end object detector. The text details the proposed architecture's efficiency improvements over existing DETR and YOLO models, specifically addressing computational bottlenecks and query initialization. It also provides a literature review of related real-time and end-to-end detection frameworks.</data>
      <data key="source_id">chunk-a5620b1fca659e335baa5d632dacaf7a</data>
      <data key="file_path">23rfewdq.pdf</data>
      <data key="created_at">1773518805</data>
    </node>
    <node id="Object Detection NMS Analysis Page (image)">
      <data key="entity_id">Object Detection NMS Analysis Page (image)</data>
      <data key="entity_type">image</data>
      <data key="description">This image is a page from a technical paper analyzing the end-to-end speed of object detectors, specifically focusing on Non-Maximum Suppression (NMS). It features a bar chart comparing box counts for YOLOv5 and YOLOv8 across different confidence thresholds, and a table detailing the trade-offs between accuracy (AP) and execution time (NMS ms) when adjusting IoU and confidence thresholds. The text explains the experimental setup involving TensorRT and the COCO dataset.</data>
      <data key="source_id">chunk-89fe41d130febd8488eedbf7569af292</data>
      <data key="file_path">23rfewdq.pdf</data>
      <data key="created_at">1773518805</data>
    </node>
    <node id="RT-DETR Performance Comparison Chart (image) [image_asset p0]">
      <data key="entity_type">image_asset</data>
      <data key="description">This image presents Figure 1 from the RT-DETR research paper, illustrating a performance benchmark between the proposed RT-DETR model and existing YOLO series detectors (v5 through v8). The scatter plot maps COCO Average Precision (AP) against inference latency on a T4 GPU. It visually substantiates the paper's claim that RT-DETR achieves superior speed-accuracy trade-offs, positioning the red RT-DETR curve above and to the left of competing models, indicating higher accuracy with lower latency.</data>
      <data key="source_id">image_asset:img-c7e92bc78f11d760a3c2e6a1ae023b5b</data>
      <data key="is_image_node">1</data>
      <data key="img_path">C:\Users\lqx94\Documents\GitHub\doc\data\#00045\knowledge\multimodal\images\img-c7e92bc78f11d760a3c2e6a1ae023b5b.png</data>
      <data key="file_path">23rfewdq.pdf</data>
      <data key="page_idx">0</data>
      <data key="doc_id">doc-7c38a573df76662c91d65cf745c83d09</data>
      <data key="created_at">1773518809</data>
    </node>
    <node id="RT-DETR Paper Page 2 (image) [image_asset p1]">
      <data key="entity_type">image_asset</data>
      <data key="description">This image shows page 2 of the research paper introducing RT-DETR, a real-time end-to-end object detector. The text details the proposed architecture's efficiency improvements over existing DETR and YOLO models, specifically addressing computational bottlenecks and query initialization. It also provides a literature review of related real-time and end-to-end detection frameworks.</data>
      <data key="source_id">image_asset:img-656e2fdc5c18c5006c4809f0f585c889</data>
      <data key="is_image_node">1</data>
      <data key="img_path">C:\Users\lqx94\Documents\GitHub\doc\data\#00045\knowledge\multimodal\images\img-656e2fdc5c18c5006c4809f0f585c889.png</data>
      <data key="file_path">23rfewdq.pdf</data>
      <data key="page_idx">1</data>
      <data key="doc_id">doc-7c38a573df76662c91d65cf745c83d09</data>
      <data key="created_at">1773518809</data>
    </node>
    <node id="Object Detection NMS Analysis Page (image) [image_asset p2]">
      <data key="entity_type">image_asset</data>
      <data key="description">This image is a page from a technical paper analyzing the end-to-end speed of object detectors, specifically focusing on Non-Maximum Suppression (NMS). It features a bar chart comparing box counts for YOLOv5 and YOLOv8 across different confidence thresholds, and a table detailing the trade-offs between accuracy (AP) and execution time (NMS ms) when adjusting IoU and confidence thresholds. The text explains the experimental setup involving TensorRT and the COCO dataset.</data>
      <data key="source_id">image_asset:img-891be2d41992c945d755cefdee89bde4</data>
      <data key="is_image_node">1</data>
      <data key="img_path">C:\Users\lqx94\Documents\GitHub\doc\data\#00045\knowledge\multimodal\images\img-891be2d41992c945d755cefdee89bde4.png</data>
      <data key="file_path">23rfewdq.pdf</data>
      <data key="page_idx">2</data>
      <data key="doc_id">doc-7c38a573df76662c91d65cf745c83d09</data>
      <data key="created_at">1773518809</data>
    </node>
