      <data key="truncate" />
    </node>
    <node id="Non-Maximum Suppression">
      <data key="entity_id">Non-Maximum Suppression</data>
      <data key="entity_type">concept</data>
      <data key="description">Non-Maximum Suppression (NMS) is a post-processing step used in object detection to remove redundant detections.&lt;SEP&gt;Non-Maximum Suppression is a post-processing technique used in object detection to eliminate redundant detections.&lt;SEP&gt;Non-Maximum Suppression is a technique used to eliminate overlapping detections in object detection.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-a5620b1fca659e335baa5d632dacaf7a&lt;SEP&gt;chunk-89fe41d130febd8488eedbf7569af292</data>
