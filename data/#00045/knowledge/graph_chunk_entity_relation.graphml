  <graph edgedefault="undirected">
    <node id="DETR">
      <data key="entity_id">DETR</data>
      <data key="entity_type">concept</data>
      <data key="description">DETR refers to end-to-end Transformer-based object detection models that eliminate the need for Non-Maximum Suppression (NMS).&lt;SEP&gt;DETR is an end-to-end object detection model based on the Transformer architecture, which RT-DETR improves upon.&lt;SEP&gt;DETR is an end-to-end object detection model based on the Transformer architecture.&lt;SEP&gt;DETR is a Transformer-based object detection model that eliminates the need for Non-Maximum Suppression (NMS).</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-901133dd8268b83119819931e3df4d8a&lt;SEP&gt;chunk-a5620b1fca659e335baa5d632dacaf7a</data>
      <data key="file_path">23rfewdq.pdf</data>
      <data key="created_at">1773518834</data>
      <data key="truncate" />
    </node>
    <node id="YOLO">
      <data key="entity_id">YOLO</data>
      <data key="entity_type">concept</data>
      <data key="description">YOLO is a series of real-time object detection frameworks known for their balance between speed and accuracy.&lt;SEP&gt;YOLO is a series of real-time object detection models known for their speed and simplicity.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-a5620b1fca659e335baa5d632dacaf7a</data>
