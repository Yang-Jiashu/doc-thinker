    <node id="Objects365">
      <data key="entity_id">Objects365</data>
      <data key="entity_type">data</data>
      <data key="description">Objects365 is a large-scale dataset used for pre-training object detection models.&lt;SEP&gt;Objects365 is a pre-training dataset used to improve the performance of RTDETR-R50/R101.&lt;SEP&gt;Objects365 is a large-scale dataset used for pre-training RT-DETR models.</data>
