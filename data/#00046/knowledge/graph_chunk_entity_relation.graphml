    <edge source="DETRs Beat YOLOs on Real-time Object Detection" target="Scatter Plot">
      <data key="weight">1.0</data>
      <data key="description">The research paper titled "DETRs Beat YOLOs on Real-time Object Detection" includes a scatter plot that visually compares the performance of various object detection models.</data>
      <data key="keywords">data visualization,research paper</data>
