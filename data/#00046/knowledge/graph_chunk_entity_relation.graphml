    <node id="Uncertainty-Minimal Query Selection">
      <data key="entity_id">Uncertainty-Minimal Query Selection</data>
      <data key="entity_type">method</data>
      <data key="description">Uncertainty-Minimal Query Selection is a technique proposed in the paper to improve the quality of initial queries in the decoder.&lt;SEP&gt;Uncertainty-Minimal Query Selection is a technique used in RT-DETR to select high-quality initial queries for the decoder.&lt;SEP&gt;Uncertainty-minimal query selection is a technique used in RT-DETR to improve accuracy.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-901133dd8268b83119819931e3df4d8a&lt;SEP&gt;chunk-26cfae2ad2694995356b094cdbaad0e3&lt;SEP&gt;chunk-e238e07664cabcd0111d4240219d3a67</data>
      <data key="file_path">23rfewdq.pdf</data>
      <data key="created_at">1773520119</data>
      <data key="truncate" />
    </node>
    <node id="Hybrid Encoder">
      <data key="entity_id">Hybrid Encoder</data>
      <data key="entity_type">artifact</data>
      <data key="description">Hybrid Encoder is a component of RT-DETR designed to efficiently process multi-scale features.&lt;SEP&gt;Hybrid Encoder is an efficient design introduced in RT-DETR to replace the vanilla Transformer encoder, improving inference speed.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-901133dd8268b83119819931e3df4d8a&lt;SEP&gt;chunk-26cfae2ad2694995356b094cdbaad0e3</data>
      <data key="file_path">23rfewdq.pdf</data>
      <data key="created_at">1773520056</data>
      <data key="truncate" />
    </node>
    <node id="Multi-Scale Features">
      <data key="entity_id">Multi-Scale Features</data>
      <data key="entity_type">concept</data>
      <data key="description">Multi-Scale Features refer to features extracted at different scales to capture objects of varying sizes.&lt;SEP&gt;Multi-Scale Features are used in RT-DETR to improve inference speed by decoupling intra-scale interaction and cross-scale fusion.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-26cfae2ad2694995356b094cdbaad0e3</data>
      <data key="file_path">23rfewdq.pdf</data>
      <data key="created_at">1773520056</data>
      <data key="truncate" />
    </node>
    <node id="Real-Time DEtection TRansformer">
      <data key="entity_id">Real-Time DEtection TRansformer</data>
      <data key="entity_type">artifact</data>
      <data key="description">Real-Time DEtection TRansformer (RT-DETR) is a real-time end-to-end object detection model proposed in the paper, designed to outperform YOLOs in both speed and accuracy.&lt;SEP&gt;Real-Time DEtection TRansformer is the full name of RT-DETR, representing a novel approach to real-time object detection.&lt;SEP&gt;RT-DETR is a proposed real-time object detection model introduced in the paper.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-901133dd8268b83119819931e3df4d8a&lt;SEP&gt;chunk-26cfae2ad2694995356b094cdbaad0e3&lt;SEP&gt;chunk-e238e07664cabcd0111d4240219d3a67</data>
