    <node id="Computational Redundancy">
      <data key="entity_id">Computational Redundancy</data>
      <data key="entity_type">concept</data>
      <data key="description">Computational redundancy refers to the inefficiency in processing steps within DETRs, which the paper aims to address.</data>
