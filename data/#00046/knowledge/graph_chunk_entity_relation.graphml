  <graph edgedefault="undirected">
    <node id="DETR">
      <data key="entity_id">DETR</data>
      <data key="entity_type">concept</data>
      <data key="description">DETR refers to end-to-end Transformer-based object detection models that eliminate the need for Non-Maximum Suppression (NMS).&lt;SEP&gt;DETR is an end-to-end object detector based on Transformer, proposed by Carion et al., which RT-DETR improves upon.&lt;SEP&gt;DETR is a type of object detection model based on transformers, analyzed in the paper.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-901133dd8268b83119819931e3df4d8a&lt;SEP&gt;chunk-26cfae2ad2694995356b094cdbaad0e3&lt;SEP&gt;chunk-e238e07664cabcd0111d4240219d3a67</data>
      <data key="file_path">23rfewdq.pdf</data>
      <data key="created_at">1773520122</data>
      <data key="truncate" />
    </node>
    <node id="YOLO">
      <data key="entity_id">YOLO</data>
      <data key="entity_type">concept</data>
      <data key="description">YOLO is a series of real-time object detection frameworks known for their balance between speed and accuracy.&lt;SEP&gt;YOLO is a family of real-time object detection models, discussed in the paper as a baseline for comparison.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-e238e07664cabcd0111d4240219d3a67</data>
      <data key="file_path">23rfewdq.pdf</data>
      <data key="created_at">1773520122</data>
      <data key="truncate" />
    </node>
    <node id="RT-DETR">
      <data key="entity_id">RT-DETR</data>
      <data key="entity_type">artifact</data>
      <data key="description">RT-DETR is a real-time end-to-end object detection model proposed in the paper, designed to outperform YOLOs in both speed and accuracy.&lt;SEP&gt;RT-DETR is a real-time object detection model that focuses on reducing computational costs and optimizing query initialization.&lt;SEP&gt;RT-DETR is a real-time end-to-end object detector proposed in the text, designed to improve inference speed and accuracy.&lt;SEP&gt;RT-DETR is an object detection model mentioned in the text.&lt;SEP&gt;RT-DETR is an object detection model represented by red circles in the scatter plot, labeled as "Ours" in the legend.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-901133dd8268b83119819931e3df4d8a&lt;SEP&gt;chunk-26cfae2ad2694995356b094cdbaad0e3&lt;SEP&gt;chunk-9787ab1eef36eba4258be0a61d000c67&lt;SEP&gt;chunk-d809e0e1bcdd4c9f8a94aed63c30ee41&lt;SEP&gt;chunk-d827c15f5e7f24992576a42cc0d70b86&lt;SEP&gt;chunk-e238e07664cabcd0111d4240219d3a67</data>
      <data key="file_path">23rfewdq.pdf</data>
      <data key="created_at">1773520119</data>
      <data key="truncate" />
    </node>
    <node id="Non-Maximum Suppression">
      <data key="entity_id">Non-Maximum Suppression</data>
      <data key="entity_type">concept</data>
      <data key="description">Non-Maximum Suppression (NMS) is a post-processing step used in object detection to remove redundant detections.&lt;SEP&gt;Non-Maximum Suppression is a technique used in object detection to remove redundant predictions.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-e238e07664cabcd0111d4240219d3a67</data>
