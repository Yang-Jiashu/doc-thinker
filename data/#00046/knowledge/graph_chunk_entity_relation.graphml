    <node id="Confidence Threshold">
      <data key="entity_id">Confidence Threshold</data>
      <data key="entity_type">concept</data>
      <data key="description">Confidence Threshold is a parameter in NMS that filters out prediction boxes with scores below a specified value.&lt;SEP&gt;Confidence Threshold is a parameter in NMS that determines the minimum confidence level for box selection.&lt;SEP&gt;Confidence threshold is a parameter used in object detection models to filter detected boxes.&lt;SEP&gt;Confidence threshold is a parameter used in object detection to filter out low-confidence predictions.</data>
      <data key="source_id">chunk-901133dd8268b83119819931e3df4d8a&lt;SEP&gt;chunk-fa4af6ae5dd3026673000e2a6ea963b9&lt;SEP&gt;chunk-26cfae2ad2694995356b094cdbaad0e3&lt;SEP&gt;chunk-9787ab1eef36eba4258be0a61d000c67&lt;SEP&gt;chunk-e238e07664cabcd0111d4240219d3a67&lt;SEP&gt;chunk-d827c15f5e7f24992576a42cc0d70b86</data>
