    <node id="NMS">
      <data key="entity_id">NMS</data>
      <data key="entity_type">concept</data>
      <data key="description">NMS refers to Non-Maximum Suppression, a technique used in object detection to filter out redundant bounding boxes.&lt;SEP&gt;NMS is a post-processing algorithm used in object detection to eliminate overlapping output boxes by applying confidence and IoU thresholds.&lt;SEP&gt;NMS is a post-processing algorithm used in object detection to eliminate overlapping output boxes.&lt;SEP&gt;NMS stands for Non-Maximum Suppression, a technique used to eliminate overlapping bounding boxes.&lt;SEP&gt;NMS refers to Non-Maximum Suppression, a technique used in object detection to eliminate redundant predictions.</data>
      <data key="source_id">chunk-901133dd8268b83119819931e3df4d8a&lt;SEP&gt;chunk-fa4af6ae5dd3026673000e2a6ea963b9&lt;SEP&gt;chunk-dc05f1e79ad134acf9e30a544b6cc7d9&lt;SEP&gt;chunk-26cfae2ad2694995356b094cdbaad0e3&lt;SEP&gt;chunk-9787ab1eef36eba4258be0a61d000c67&lt;SEP&gt;chunk-52ae1ab29b34a3bd4356efa630d2730c&lt;SEP&gt;chunk-e238e07664cabcd0111d4240219d3a67&lt;SEP&gt;chunk-d827c15f5e7f24992576a42cc0d70b86</data>
