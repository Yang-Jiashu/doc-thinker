      <data key="entity_id">DINO</data>
      <data key="entity_type">artifact</data>
      <data key="description">DINO is another object detection model that RT-DETR outperforms in terms of accuracy and speed.&lt;SEP&gt;DINO is an object detection model discussed in the text.&lt;SEP&gt;DINO is another variant of DETR discussed in the paper's related work section.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-901133dd8268b83119819931e3df4d8a&lt;SEP&gt;chunk-e238e07664cabcd0111d4240219d3a67&lt;SEP&gt;chunk-d827c15f5e7f24992576a42cc0d70b86</data>
