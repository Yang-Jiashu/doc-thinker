    <node id="Object Detection">
      <data key="entity_id">Object Detection</data>
      <data key="entity_type">concept</data>
      <data key="description">Object detection is the task of identifying and localizing objects within images or videos.&lt;SEP&gt;Object Detection is the task of identifying and locating objects within images or videos.&lt;SEP&gt;Object detection is the task of identifying and localizing objects within an image, which is the focus of the research paper.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-26cfae2ad2694995356b094cdbaad0e3&lt;SEP&gt;chunk-e238e07664cabcd0111d4240219d3a67</data>
      <data key="file_path">23rfewdq.pdf</data>
      <data key="created_at">1773520122</data>
      <data key="truncate" />
    </node>
    <node id="Real-Time Object Detection">
      <data key="entity_id">Real-Time Object Detection</data>
      <data key="entity_type">concept</data>
      <data key="description">Real-Time Object Detection refers to the ability of a model to detect objects quickly enough for real-time applications.&lt;SEP&gt;Real-Time Object Detection is the goal of RT-DETR, aiming to achieve fast and accurate detection without retraining.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-26cfae2ad2694995356b094cdbaad0e3</data>
      <data key="file_path">23rfewdq.pdf</data>
      <data key="created_at">1773520056</data>
      <data key="truncate" />
    </node>
    <node id="T4 GPU">
      <data key="entity_id">T4 GPU</data>
      <data key="entity_type">naturalobject</data>
      <data key="description">T4 GPU is a type of graphics processing unit used for running and benchmarking object detection models.&lt;SEP&gt;T4 GPU is a graphics processing unit used for testing the speed of NMS operations.&lt;SEP&gt;T4 GPU is a hardware platform on which RT-DETR achieves 108 FPS.</data>
      <data key="source_id">chunk-304395e843a4ed6d59b25d1e18f87724&lt;SEP&gt;chunk-901133dd8268b83119819931e3df4d8a&lt;SEP&gt;chunk-fa4af6ae5dd3026673000e2a6ea963b9&lt;SEP&gt;chunk-26cfae2ad2694995356b094cdbaad0e3&lt;SEP&gt;chunk-9787ab1eef36eba4258be0a61d000c67</data>
