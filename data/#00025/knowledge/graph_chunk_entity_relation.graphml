  <graph edgedefault="undirected">
    <node id="李飞飞">
      <data key="entity_id">李飞飞</data>
      <data key="entity_type">person</data>
      <data key="description">李飞飞is a renowned scholar who graduated from Princeton University in 1999, conducted research on Tibetan medicine in Tibet, studied at the California Institute of Technology, and later worked as an assistant professor at the University of Illinois at Urbana-Champaign and Princeton University. She is recognized for her significant contributions to artificial intelligence and computer science.</data>
      <data key="source_id">chunk-6e74d4c894ef8b424ec5c13f46dd0535</data>
      <data key="file_path">unknown_source</data>
      <data key="created_at">1772947070</data>
      <data key="truncate" />
    </node>
    <node id="普林斯顿大学">
      <data key="entity_id">普林斯顿大学</data>
      <data key="entity_type">organization</data>
      <data key="description">普林斯顿大学is a top-tier international university that served as the undergraduate institution of李飞飞and later employed her as an assistant professor in the Department of Computer Science.</data>
      <data key="source_id">chunk-6e74d4c894ef8b424ec5c13f46dd0535</data>
      <data key="file_path">unknown_source</data>
      <data key="created_at">1772947070</data>
      <data key="truncate" />
    </node>
    <node id="加州理工学院">
      <data key="entity_id">加州理工学院</data>
      <data key="entity_type">organization</data>
      <data key="description">加州理工学院, also known as the California Institute of Technology, is a leading research institution where李飞飞pursued further study beginning in 2000 and obtained a doctoral degree in 2005.</data>
      <data key="source_id">chunk-6e74d4c894ef8b424ec5c13f46dd0535</data>
      <data key="file_path">unknown_source</data>
      <data key="created_at">1772947070</data>
      <data key="truncate" />
    </node>
    <node id="伊利诺伊大学厄巴纳-香槟分校">
      <data key="entity_id">伊利诺伊大学厄巴纳-香槟分校</data>
      <data key="entity_type">organization</data>
      <data key="description">伊利诺伊大学厄巴纳-香槟分校is a prestigious university where李飞飞worked as an assistant professor in the Department of Electrical Engineering from 2005 to 2006.</data>
      <data key="source_id">chunk-6e74d4c894ef8b424ec5c13f46dd0535</data>
      <data key="file_path">unknown_source</data>
      <data key="created_at">1772947070</data>
      <data key="truncate" />
    </node>
    <node id="西藏">
      <data key="entity_id">西藏</data>
      <data key="entity_type">location</data>
      <data key="description">西藏, or Tibet, is the region where李飞飞conducted a year-long research project on Tibetan medicine after her undergraduate graduation.</data>
      <data key="source_id">chunk-6e74d4c894ef8b424ec5c13f46dd0535</data>
      <data key="file_path">unknown_source</data>
      <data key="created_at">1772947070</data>
