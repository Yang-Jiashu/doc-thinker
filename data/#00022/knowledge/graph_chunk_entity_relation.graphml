  <graph edgedefault="undirected">
    <node id="I/O System">
      <data key="entity_id">I/O System</data>
      <data key="entity_type">concept</data>
      <data key="description">The I/O System refers to the subsystem responsible for managing input and output operations and devices within a computing environment.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="I/O Device">
      <data key="entity_id">I/O Device</data>
      <data key="entity_type">artifact</data>
      <data key="description">I/O Device includes both input and output devices that communicate data between the computer and external environment.&lt;SEP&gt;The I/O Device is a generic label for computer peripherals connected to the I/O interface, including units like Keyboard, Mouse, Display, Printer, and Disk.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf&lt;SEP&gt;chunk-19270e62cbd06938de14ab5cb2085199</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889488</data>
      <data key="truncate" />
    </node>
    <node id="I/O Interface">
      <data key="entity_id">I/O Interface</data>
      <data key="entity_type">artifact</data>
      <data key="description">I/O Interface defines the medium and rules by which I/O devices connect and communicate with a computer system, including parallel and serial interfaces.&lt;SEP&gt;The I/O Interface represents the circuitry that enables communication between the I/O Controller and external I/O devices.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf&lt;SEP&gt;chunk-19270e62cbd06938de14ab5cb2085199</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889488</data>
      <data key="truncate" />
    </node>
    <node id="I/O Controller">
      <data key="entity_id">I/O Controller</data>
      <data key="entity_type">artifact</data>
      <data key="description">I/O Controller is a device or circuit that manages data exchange and control signals between the computer system and I/O devices, including general and special purpose types.&lt;SEP&gt;The I/O Controller is a functional hardware unit positioned below the CPU, managing the coordination and execution of input/output operations.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf&lt;SEP&gt;chunk-19270e62cbd06938de14ab5cb2085199</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889488</data>
      <data key="truncate" />
    </node>
    <node id="I/O Channel">
      <data key="entity_id">I/O Channel</data>
      <data key="entity_type">concept</data>
      <data key="description">I/O Channel is a dedicated pathway or subsystem for managing data transfers between memory and peripheral devices, including selection channels and multiplex channels.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="I/O Port">
      <data key="entity_id">I/O Port</data>
      <data key="entity_type">artifact</data>
      <data key="description">I/O Port serves as a physical connection point for input or output signals to enter or leave a system.&lt;SEP&gt;The I/O Port serves as an access point between the I/O Interface and I/O Devices, facilitating communication and data transfer.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf&lt;SEP&gt;chunk-19270e62cbd06938de14ab5cb2085199</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889488</data>
      <data key="truncate" />
    </node>
    <node id="I/O Buffer">
      <data key="entity_id">I/O Buffer</data>
      <data key="entity_type">artifact</data>
      <data key="description">I/O Buffer is an area of memory used to temporarily store data during transfer between the CPU and I/O devices.&lt;SEP&gt;The I/O Buffer is an intermediate storage block between the I/O Interface and I/O Devices, providing temporary data buffering.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf&lt;SEP&gt;chunk-19270e62cbd06938de14ab5cb2085199</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889488</data>
      <data key="truncate" />
    </node>
    <node id="I/O Instruction">
      <data key="entity_id">I/O Instruction</data>
      <data key="entity_type">concept</data>
      <data key="description">I/O Instruction is a command in a computer system that initiates an input or output operation.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="I/O Operation">
      <data key="entity_id">I/O Operation</data>
      <data key="entity_type">method</data>
      <data key="description">I/O Operation is the process or sequence of steps for performing input or output actions in a computer system.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="I/O Mode">
      <data key="entity_id">I/O Mode</data>
      <data key="entity_type">concept</data>
      <data key="description">I/O Mode refers to the method by which data transfer is managed in the I/O System, including program polling, interrupt, DMA, and channel modes.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="Parallel Interface">
      <data key="entity_id">Parallel Interface</data>
      <data key="entity_type">artifact</data>
      <data key="description">Parallel Interface is a type of I/O Interface that transfers multiple bits simultaneously.&lt;SEP&gt;The Parallel Interface is a specific type of I/O interface that enables parallel communication with certain external devices.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf&lt;SEP&gt;chunk-19270e62cbd06938de14ab5cb2085199</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889488</data>
      <data key="truncate" />
    </node>
    <node id="Serial Interface">
      <data key="entity_id">Serial Interface</data>
      <data key="entity_type">artifact</data>
      <data key="description">Serial Interface is a type of I/O interface that transmits data one bit at a time, sequentially.&lt;SEP&gt;The Serial Interface is a specific type of I/O interface that enables serial communication with external devices.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf&lt;SEP&gt;chunk-19270e62cbd06938de14ab5cb2085199</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889488</data>
      <data key="truncate" />
    </node>
    <node id="Data Register">
      <data key="entity_id">Data Register</data>
      <data key="entity_type">artifact</data>
      <data key="description">Data Register is a component of an I/O interface used to hold data being transferred to or from a device.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="Status Register">
      <data key="entity_id">Status Register</data>
      <data key="entity_type">artifact</data>
      <data key="description">Status Register is a component of an I/O interface that holds information about the current state of the device or operation.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="Control Register">
      <data key="entity_id">Control Register</data>
      <data key="entity_type">artifact</data>
      <data key="description">Control Register is a part of the I/O interface used to manage and configure the operations of a connected I/O device.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="Data Buffer Register">
      <data key="entity_id">Data Buffer Register</data>
      <data key="entity_type">artifact</data>
      <data key="description">Data Buffer Register is used to temporarily store data during the transfer between the CPU and an I/O device.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="General Controller">
      <data key="entity_id">General Controller</data>
      <data key="entity_type">artifact</data>
      <data key="description">General Controller is a type of I/O Controller designed for use with a range of I/O devices.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="Dedicated Controller">
      <data key="entity_id">Dedicated Controller</data>
      <data key="entity_type">artifact</data>
      <data key="description">Dedicated Controller is an I/O Controller specialized for a specific device or operation.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="Selector Channel">
      <data key="entity_id">Selector Channel</data>
      <data key="entity_type">artifact</data>
      <data key="description">Selector Channel is an I/O Channel that can manage data transfer for one device at a time with high speed.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="Multiplexer Channel">
      <data key="entity_id">Multiplexer Channel</data>
      <data key="entity_type">artifact</data>
      <data key="description">Multiplexer Channel is an I/O Channel that allows multiple devices to share the same channel for I/O transfers concurrently.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="Input Port">
      <data key="entity_id">Input Port</data>
      <data key="entity_type">artifact</data>
      <data key="description">Input Port is a type of I/O port dedicated to receiving incoming data from an external source.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="Output Port">
      <data key="entity_id">Output Port</data>
      <data key="entity_type">artifact</data>
      <data key="description">Output Port is a type of I/O port dedicated to sending data to an external device.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="Bidirectional Port">
      <data key="entity_id">Bidirectional Port</data>
      <data key="entity_type">artifact</data>
      <data key="description">Bidirectional Port is a type of I/O Port capable of both input and output operations.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="Input Buffer">
      <data key="entity_id">Input Buffer</data>
      <data key="entity_type">artifact</data>
      <data key="description">Input Buffer is a type of I/O buffer used for temporarily storing incoming data.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="Output Buffer">
      <data key="entity_id">Output Buffer</data>
      <data key="entity_type">artifact</data>
      <data key="description">Output Buffer is a type of I/O buffer used for temporarily storing outgoing data.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="Bidirectional Buffer">
      <data key="entity_id">Bidirectional Buffer</data>
      <data key="entity_type">artifact</data>
      <data key="description">Bidirectional Buffer is a type of I/O Buffer that can store both incoming and outgoing data.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="Input Instruction">
      <data key="entity_id">Input Instruction</data>
      <data key="entity_type">concept</data>
      <data key="description">Input Instruction is an I/O command for receiving data from an input device.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="Output Instruction">
      <data key="entity_id">Output Instruction</data>
      <data key="entity_type">concept</data>
      <data key="description">Output Instruction is an I/O instruction used to write data from the system to a device.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="Status Instruction">
      <data key="entity_id">Status Instruction</data>
      <data key="entity_type">concept</data>
      <data key="description">Status Instruction is an I/O instruction used to check or report the current state of an I/O device or operation.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="Control Instruction">
      <data key="entity_id">Control Instruction</data>
      <data key="entity_type">concept</data>
      <data key="description">Control Instruction is an I/O instruction that manages or changes the behavior of an I/O device.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="Program Polling Mode">
      <data key="entity_id">Program Polling Mode</data>
      <data key="entity_type">method</data>
      <data key="description">Program Polling Mode is an I/O Mode where the CPU repeatedly checks device status to manage I/O.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="Interrupt Mode">
      <data key="entity_id">Interrupt Mode</data>
      <data key="entity_type">method</data>
      <data key="description">Interrupt Mode is an I/O Mode where the device interrupts the CPU to request service.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889445</data>
      <data key="truncate" />
    </node>
    <node id="DMA Mode">
      <data key="entity_id">DMA Mode</data>
      <data key="entity_type">method</data>
      <data key="description">DMA Mode (Direct Memory Access Mode) is an I/O method allowing peripherals to communicate with memory without CPU intervention.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889446</data>
      <data key="truncate" />
    </node>
    <node id="Channel Mode">
      <data key="entity_id">Channel Mode</data>
      <data key="entity_type">method</data>
      <data key="description">Channel Mode is an I/O method that utilizes dedicated I/O channels for data transfer, freeing the CPU from direct control.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889447</data>
      <data key="truncate" />
    </node>
    <node id="Input Device">
      <data key="entity_id">Input Device</data>
      <data key="entity_type">artifact</data>
      <data key="description">Input Device is a type of I/O device used for providing data and instructions to a computer system, including examples such as keyboards, mice, scanners, and cameras.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889447</data>
      <data key="truncate" />
    </node>
    <node id="Output Device">
      <data key="entity_id">Output Device</data>
      <data key="entity_type">artifact</data>
      <data key="description">Output Device is a type of I/O device used to display or produce results from computer processing, examples include monitors, printers, and plotters.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889447</data>
      <data key="truncate" />
    </node>
    <node id="Keyboard">
      <data key="entity_id">Keyboard</data>
      <data key="entity_type">artifact</data>
      <data key="description">Keyboard is an input device used to enter data and commands into a computer system.&lt;SEP&gt;The Keyboard is an input device connected to the I/O interface for user data entry.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf&lt;SEP&gt;chunk-19270e62cbd06938de14ab5cb2085199</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889488</data>
      <data key="truncate" />
    </node>
    <node id="Mouse">
      <data key="entity_id">Mouse</data>
      <data key="entity_type">artifact</data>
      <data key="description">Mouse is an input device used to interact with a computer through cursor movement and clicking.&lt;SEP&gt;The Mouse is an input device connected to the I/O interface, used for pointer input and control.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf&lt;SEP&gt;chunk-19270e62cbd06938de14ab5cb2085199</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889488</data>
      <data key="truncate" />
    </node>
    <node id="Scanner">
      <data key="entity_id">Scanner</data>
      <data key="entity_type">artifact</data>
      <data key="description">Scanner is an input device for digitizing physical documents into electronic form.</data>
      <data key="source_id">chunk-d8545ba2c852169e269183de89d6c5bf</data>
      <data key="file_path">Chap1 计算机系统概述.pdf</data>
      <data key="created_at">1772889447</data>
      <data key="truncate" />
    </node>
    <node id="Camera">
      <data key="entity_id">Camera</data>
      <data key="entity_type">artifact</data>
      <data key="description">Camera is an input device used to capture visual information and input it into a computer system.</data>
